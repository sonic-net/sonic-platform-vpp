+			   clib_mem_unaligned (&ip6->src_address.as_uword[1], uword),
+			   clib_mem_unaligned (&ip6->dst_address.as_uword[0], uword),
+			   clib_mem_unaligned (&ip6->dst_address.as_uword[1], uword), a);
+      return hash;
+    }
+
+  hash_eth_l2 (p, &hash, 1);
