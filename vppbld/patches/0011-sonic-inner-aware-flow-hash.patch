+      hash[0] = hash_eth_l34_inner_inline (&p[0]);
+      hash[1] = hash_eth_l34_inner_inline (&p[1]);
+      hash[2] = hash_eth_l34_inner_inline (&p[2]);
+      hash[3] = hash_eth_l34_inner_inline (&p[3]);
+
+      hash += 4;
+      n_left_from -= 4;
+      p += 4;
+    }
+
+  while (n_left_from > 0)
+    {
+      hash[0] = hash_eth_l34_inner_inline (&p[0]);
+
+      hash += 1;
+      n_left_from -= 1;
+      p += 1;
+    }
