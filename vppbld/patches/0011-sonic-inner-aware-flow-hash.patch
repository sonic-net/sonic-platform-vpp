+       * not extension headers); a future enhancement could walk them. */
+      u32 payload_length = clib_net_to_host_u16 (ip6->payload_length);
+      ip_inner_resolve (ip6->protocol, (const u8 *) (ip6 + 1), payload_length, &inner);
+      if (inner.valid)
